generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  role            String    @default("Âme tentée")
  discordRolesRaw String    @default("[]")
  tagsRaw         String    @default("[]")
  bio             String?
  status          String?   @default("En attente de tentation")
  
  // Préférences de visibilité
  isPublic        Boolean   @default(true)
  isAnonymous     Boolean   @default(false)
  isGalleryPublic Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  accounts        Account[]
  posts           Post[]
  sessions        Session[]
  comments        Comment[] @relation("ProfileComments")
  writtenComments Comment[] @relation("AuthoredComments")
  
  // Vues de profil
  profileViews    ProfileView[] @relation("ProfileOwner")
  viewedProfiles  ProfileView[] @relation("ProfileVisitor")

  // Favoris (Coups de cœur)
  favorites       Favorite[]    @relation("UserFavorites") // Ceux que j'ai mis en favoris
  favoritedBy     Favorite[]    @relation("UserFavoritedBy") // Ceux qui m'ont mis en favoris

  // Galerie Média
  media           Media[]

  // Messagerie
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  conversations    Conversation[] @relation("UserConversations")
}

model Favorite {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  // Celui qui met en favori
  userId      String
  user        User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  
  // Celui qui est mis en favori
  targetId    String
  target      User     @relation("UserFavoritedBy", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}

model Media {
  id          String   @id @default(cuid())
  url         String
  type        String   @default("image") // image ou video
  caption     String?
  isNSFW      Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  participants User[]   @relation("UserConversations")
  messages     Message[]
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  isRead         Boolean      @default(false)
  
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId     String
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ProfileView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  
  // Celui qui est visité
  profileId String
  profile   User     @relation("ProfileOwner", fields: [profileId], references: [id], onDelete: Cascade)
  
  // Celui qui visite
  visitorId String
  visitor   User     @relation("ProfileVisitor", fields: [visitorId], references: [id], onDelete: Cascade)

  @@unique([profileId, visitorId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  
  // L'auteur du commentaire
  authorId  String
  author    User     @relation("AuthoredComments", fields: [authorId], references: [id], onDelete: Cascade)
  
  // Le profil sur lequel le commentaire est posté
  profileId String
  profile   User     @relation("ProfileComments", fields: [profileId], references: [id], onDelete: Cascade)
  
  // Gestion des réponses
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
